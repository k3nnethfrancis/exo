{
  "name": "exo",
  "private": true,
  "version": "0.1.0-alpha.2",
  "description": "Local-first agentic development environment built around a shared exocortex for humans and terminal agents.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "EXO_WORKSPACE_ROOT=${EXO_WORKSPACE_ROOT:-$PWD} EXO_DEFAULT_TERMINAL_CWD=${EXO_DEFAULT_TERMINAL_CWD:-$PWD} pnpm --filter @exo/desktop dev",
    "dev:qa": "EXO_WORKSPACE_ROOT=${EXO_WORKSPACE_ROOT:-$PWD} EXO_RUNTIME_ROOT=${EXO_RUNTIME_ROOT:-$PWD/.exo-dev} EXO_USER_DATA_PATH=${EXO_USER_DATA_PATH:-$PWD/.exo-dev/user-data} EXO_DEFAULT_TERMINAL_CWD=${EXO_DEFAULT_TERMINAL_CWD:-$PWD} pnpm --filter @exo/desktop dev",
    "exo": "tsx packages/cli/src/index.ts",
    "install:local": "scripts/install-local",
    "install:mac-app": "scripts/install-mac-app",
    "check:repo": "node scripts/check-repo.mjs",
    "ci:check": "pnpm check:repo && pnpm check && ./scripts/install-local --dry-run --skip-install --skip-build",
    "app": "pnpm build && node scripts/run-built-app.mjs",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "build": "pnpm --filter @exo/desktop build && pnpm --filter @exo/cli build && pnpm --filter @exo/mcp build",
    "pack:mac": "pnpm build && electron-builder --projectDir apps/desktop --mac dir",
    "dist:mac": "pnpm build && electron-builder --projectDir apps/desktop --mac dmg zip",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --dir packages/core test && pnpm --dir apps/desktop test && pnpm --dir packages/mcp test && pnpm --dir packages/cli test",
    "test:e2e": "pnpm --filter @exo/desktop build && playwright test -c apps/desktop/playwright.config.ts",
    "test:visual": "pnpm --filter @exo/desktop build && playwright test -c apps/desktop/playwright.visual.config.ts",
    "rebuild:native": "pnpm --filter @exo/desktop rebuild:native",
    "postinstall": "pnpm --filter @exo/desktop setup:runtime && pnpm rebuild:native"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "electron-builder": "^26.8.1",
    "esbuild": "0.27.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8.0.14",
    "vitest": "4.1.0"
  }
}
