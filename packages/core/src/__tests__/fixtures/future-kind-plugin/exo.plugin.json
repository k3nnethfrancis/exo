{
  "id": "future-kind-fixture.plugin",
  "name": "Future Kind Fixture",
  "version": "0.1.0",
  "exoApiVersion": "0.1",
  "description": "Fixture with one future capability kind and one supported sibling.",
  "capabilities": [
    {
      "id": "future-kind-fixture.widget",
      "kind": "exo.future:widget",
      "label": "Future Widget",
      "description": "A capability from a future Exo version.",
      "lifecycle": "experimental",
      "owner": "future-kind-fixture.plugin",
      "surfaces": ["desktop"],
      "permissions": ["workspace:read", "artifacts:write"]
    },
    {
      "id": "future-kind-fixture.routine",
      "kind": "core:routineTemplate",
      "label": "Supported Routine",
      "description": "A supported sibling capability.",
      "lifecycle": "experimental",
      "owner": "future-kind-fixture.plugin",
      "surfaces": ["desktop", "cli"],
      "permissions": ["workspace:read"]
    }
  ],
  "permissions": ["workspace:read"],
  "surfaces": ["desktop", "cli"]
}
