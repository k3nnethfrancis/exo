#!/bin/sh
set -eu

zero_sha=0000000000000000000000000000000000000000
warned=0

while read local_ref local_sha remote_ref remote_sha
do
  [ "$local_sha" = "$zero_sha" ] && continue

  if [ "$remote_sha" = "$zero_sha" ]; then
    base="$(git merge-base "$local_sha" origin/main 2>/dev/null || true)"
    if [ -n "$base" ]; then
      range="$base..$local_sha"
    else
      range="$(git rev-list --max-parents=0 "$local_sha" | tail -1)..$local_sha"
    fi
  else
    range="$remote_sha..$local_sha"
  fi

  changed_files="$(git diff --name-only "$range" -- 2>/dev/null || git show --name-only --format= "$local_sha")"

  if [ -n "$changed_files" ] && ! printf '%s\n' "$changed_files" | grep -q '^CHANGELOG.md$'; then
    echo "pre-push reminder: CHANGELOG.md was not updated in the commits being pushed." >&2
    echo "pre-push reminder: add an Unreleased entry for user-visible changes before pushing when applicable." >&2
    warned=1
  fi
done

if [ "$warned" -eq 1 ]; then
  echo "pre-push reminder only; push continues." >&2
fi

exit 0
