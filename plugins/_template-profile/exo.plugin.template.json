{
  "id": "local-profile.plugin",
  "name": "Local Profile",
  "version": "0.1.0",
  "exoApiVersion": "0.1",
  "description": "Metadata-only profile pack for advisory workspace conventions.",
  "capabilities": [
    {
      "id": "local-profile.profile",
      "kind": "core:profile",
      "label": "Local Profile",
      "description": "Recommended plugins, metadata conventions, and review/output policies for a workspace profile.",
      "lifecycle": "experimental",
      "owner": "local-profile.plugin",
      "surfaces": ["desktop", "cli"],
      "permissions": ["workspace:read", "notes:read"],
      "compatibility": {
        "profile": {
          "recommendedPlugins": [
            {
              "id": "qmd",
              "required": false,
              "reason": "Advanced local Markdown search and indexing."
            }
          ],
          "metadataSchemas": [
            {
              "id": "note",
              "label": "Note",
              "description": "Advisory frontmatter fields for Markdown notes.",
              "scope": {
                "paths": ["**/*.md"]
              },
              "frontmatter": {
                "title": {
                  "type": "string",
                  "required": false
                },
                "type": {
                  "type": "string",
                  "required": false
                },
                "status": {
                  "type": "string",
                  "required": false
                }
              },
              "tags": []
            }
          ],
          "contextTemplates": [],
          "instructionTemplates": [],
          "mcpConfigTemplates": [],
          "skills": [],
          "graphViews": [],
          "analyzerSettings": [],
          "reviewPolicy": {
            "fileChanges": "propose",
            "requireHumanReview": true,
            "allowedPaths": ["**/*.md", ".exo/**"]
          }
        }
      }
    }
  ],
  "permissions": ["workspace:read", "notes:read"],
  "surfaces": ["desktop", "cli"]
}
