{
  "id": "local-routine-template.plugin",
  "name": "Local Routine Template",
  "version": "0.1.0",
  "exoApiVersion": "0.1",
  "description": "Metadata-only routine template plugin.",
  "capabilities": [
    {
      "id": "local-routine-template.template",
      "kind": "routineTemplate",
      "label": "Local Routine Template",
      "description": "Reusable prompt and policy metadata for a manually instantiated workspace routine.",
      "lifecycle": "experimental",
      "owner": "local-routine-template.plugin",
      "surfaces": ["desktop", "cli"],
      "permissions": ["workspace:read", "notes:read", "artifacts:write"],
      "compatibility": {
        "routineTemplate": {
          "prompt": "Inspect the selected workspace scope and produce a concise report with findings, evidence, and proposed follow-up actions. Do not modify files unless the instantiated routine output policy explicitly permits proposed changes.",
          "harnessId": "codex",
          "requiredSkills": [],
          "trigger": {
            "kind": "manual"
          },
          "permissions": {
            "permissions": ["workspace:read", "notes:read", "artifacts:write"]
          },
          "outputPolicy": {
            "fileChanges": "propose",
            "artifacts": "record",
            "allowedPaths": [".exo/artifacts"]
          }
        }
      }
    }
  ],
  "permissions": ["workspace:read", "notes:read", "artifacts:write"],
  "surfaces": ["desktop", "cli"]
}
