# Optional Exo runtime overrides.
# Copy to your shell profile or process environment as needed.

# EXO_WORKSPACE_ROOT=/path/to/workspace
# EXO_NOTE_ROOTS=/path/to/workspace/notes
# EXO_PROJECT_ROOTS=/path/to/project-a:/path/to/project-b
# EXO_DEFAULT_TERMINAL_CWD=/path/to/workspace
# EXO_SETTINGS_PATH=/path/to/workspace-settings.json

# Agent command overrides.
# EXO_CLAUDE_COMMAND=claude
# EXO_CLAUDE_ARGS=
# EXO_CODEX_COMMAND=codex
# EXO_CODEX_ARGS=

# MCP autostart.
# EXO_MCP_AUTOSTART=1

# Terminal transcript retention.
# EXO_TERMINAL_TRANSCRIPT_RETENTION_DAYS=14
# EXO_TERMINAL_TRANSCRIPT_MAX_TOTAL_MB=500
# EXO_TERMINAL_TRANSCRIPT_MAX_FILE_MB=50
